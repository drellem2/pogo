#!/bin/bash
# pogo-self-deploy — out-of-band pogod redeployer (mg-6afa / mg-cae1).
#
# IT DEPLOYS THE CLI TOO, AND THAT IS NOT A CONVENIENCE (mg-ddf1)
# --------------------------------------------------------------
# `do_build` installs every binary in DEPLOYED_CMDS — today `pogod` AND `pogo`.
# The CLI belongs here and nowhere else. A `pogo` newer than the running `pogod`
# risks a protocol mismatch that breaks the tooling every agent depends on,
# mid-flight (mg-49bc). A redeploy is the exact moment pogod moves to main's
# revision — which makes it the one moment the CLI can move safely, and the
# reason installing it at any OTHER time is the hazard. Lockstep, by design.
#
# Before this, `do_build` installed ./cmd/pogod alone, so no code path installed
# the CLI at all: every cmd/pogo change was merged and dark, indefinitely, with
# no signal. Not a staleness window — an absence. The CLI sat three days behind
# main while the drift check called the box clean, because it too read only the
# daemon. If you add a binary to DEPLOYED_CMDS, the drift check covers it for
# free; that coupling is deliberate, and it is what stops this recurring.
#
# WHY THIS IS A STANDALONE SCRIPT, NOT A pogod OR pogo SUBCOMMAND
# ---------------------------------------------------------------
# A thing that replaces or supervises X cannot live inside X — not inside X's
# process tree, and not inside X's change-surface (architect ruling, mg-6afa).
# pogod redeploys pogod; if the redeployer shipped *with* pogod (as a `pogod`
# or `pogo` subcommand) it would churn on every pogod change and could ship
# broken exactly when you need it to fix a broken pogod — a deploy path you
# cannot fix without the deploy path. So this is a deliberately thin, rarely-
# touched script that calls only STABLE primitives: curl, go install,
# launchctl kickstart, git rev-parse, mg unclaim. Keep it dumb.
#
# It also must run OUT OF BAND — not as a descendant of pogod — because the
# redeploy kickstart -k kills pogod's entire process tree. A human runs it
# today; a healthy-launchd one-shot may run it later (mg-6afa sequencing).
# That is ENFORCED, not merely asserted: assert_out_of_band refuses a caller
# inside pogod's tree, on cmd_redeploy's first line (mg-1bbf). It was prose
# alone until then — the one constraint in a script with sixteen refusal paths
# that nothing checked.
#
# A redeploy PROVES THE DETECTOR BEFORE IT TRUSTS IT (do_prove, mg-bfe5). After
# the build and before the kickstart, every run stands the live control up
# against the artifact it is about to deploy and refuses to proceed unless the
# mail-check post-check is observed going RED on a broken fleet AND GREEN on an
# intact one. do_build runs `go install` and no tests, so without this a redeploy
# ships a pogod whose detector has never been exercised against it; a merge-time
# pass is a claim about a commit, not a measurement of the artifact. It adds ~2min
# to a redeploy, inside the drain window. A refusal exits with the drain trap
# still armed, so the old pogod keeps running and dispatching.
#
# USAGE
#   pogo-self-deploy check                 # three-way drift report; NEVER acts
#   pogo-self-deploy redeploy [flags]      # guarded rebuild+prove+restart
#
# redeploy flags:
#   --yes                 proceed without the interactive confirmation prompt
#   --force               permit a HARD BOUNCE the drain would otherwise refuse.
#                         Two refusals, both overridden by this flag:
#                           - polecats still active after the drain timeout
#                             (kills them, then cleans up claims + worktrees)
#                           - the drain could not establish whether the fleet is
#                             idle: pogod went silent or unreadable mid-drain and
#                             the on-disk witness could not settle it (mg-65b2)
#                         Default REFUSES both — the fleet-kill footgun must be
#                         explicit (mg-6afa MVP). On the second, --force means
#                         "I know it's wedged, bounce it anyway".
#   --skip-drain          skip the drain phase entirely and go straight to
#                         rebuild+restart. Required to self-deploy ONTO a pogod
#                         that predates the /agents/drain endpoint (mg-cae1) —
#                         the one-time bootstrap chicken-and-egg (mg-065e). Also
#                         usable when the operator knows the fleet is idle.
#   --drain-timeout SECS  how long to wait for polecats to finish (default 1800)
#   --repo PATH           pogo source repo to build from (see repo resolution)
#   --port N              pogod HTTP port (default $POGO_PORT or 10000)
#
# ENV overrides: POGO_PORT, POGO_REPO, POGO_DAEMON_LABEL (default
# com.pogo.daemon), POGO_DEPLOY_REF (default main), LAUNCHCTL, POGO_GOBIN.

set -u

# ---------------------------------------------------------------------------
# Config / stable primitives
# ---------------------------------------------------------------------------
PORT="${POGO_PORT:-10000}"
DAEMON_LABEL="${POGO_DAEMON_LABEL:-com.pogo.daemon}"
DEPLOY_REF="${POGO_DEPLOY_REF:-main}"
LAUNCHCTL="${LAUNCHCTL:-launchctl}"
# The `pogo` CLI, used for ONE thing: asking the on-disk polecat witness whether
# any polecat is alive when pogod has stopped answering (drain_wait, mg-65b2).
# A variable rather than a bare `pogo` for the same reason LAUNCHCTL is one — the
# live control has to point it at a sandbox artifact instead of the machine's
# installed binary, and PATH games in a script that runs as root at 03:00 are a
# worse seam. See witness_alive_count for why this hop is not a header violation.
POGO_CLI="${POGO_CLI:-pogo}"
DRAIN_TIMEOUT=1800
# How long verify_mail_checks_restored polls for the new pogod to finish loading
# its schedules. A variable rather than a literal so the live control
# (pogo-self-deploy_live_test.sh) can drive the RED and UNKNOWN verdicts without
# burning the full window per assertion. It changes how many times the check
# probes, never what a probe does — the seam under test (curl -> parse ->
# classify -> report) is identical either way.
MAIL_CHECK_TIMEOUT=30
FORCE=false
ASSUME_YES=false
SKIP_DRAIN=false
REPO="${POGO_REPO:-}"

ts()   { date -u +%Y-%m-%dT%H:%M:%SZ; }
log()  { echo "[$(ts)] $*"; }
err()  { echo "[$(ts)] ERROR: $*" >&2; }
short(){ printf '%s' "${1:0:12}"; }

# Flat-JSON field extractors — the driver stays jq-free on purpose (one fewer
# dependency in the path that must work when everything else is broken). Go's
# json.Encoder emits single-line objects, so these single-line seds suffice.
json_str() { sed -n "s/.*\"$1\":\"\([^\"]*\)\".*/\1/p"; }
json_num() { sed -n "s/.*\"$1\":\([0-9][0-9]*\).*/\1/p"; }
# json_bool — a BARE json bool, echoing "true"/"false" (empty if the field is
# absent or is not a bool). json_str cannot do this and must not be made to: the
# value carries no quotes, which is exactly what the unit test pins when it
# asserts `json_str draining` is empty. BRE only — this runs under BSD sed on
# macOS, where GNU's \| alternation silently matches nothing.
json_bool() { sed -n "s/.*\"$1\":\([tf][a-z]*\).*/\1/p"; }

base_url() { echo "http://127.0.0.1:${PORT}"; }

# ---------------------------------------------------------------------------
# Out-of-band guard (mg-1bbf)
# ---------------------------------------------------------------------------
# The header above has said "must run OUT OF BAND — not as a descendant of
# pogod" since mg-6afa. Until this block, that was the ONE constraint in a
# script with sixteen refusal paths that had no mechanism behind it: enforced
# only by whether the caller read a 1800-line preamble.
#
# That is the wrong enforcement for this population. A human at a terminal
# reading the header is plausible; an agent told "run the redeploy" is not —
# and an agent is precisely who this forbids. Every crew agent and every polecat
# is a pogod descendant, so the actor most likely to skip the prose is the actor
# the prose exists to stop. On 2026-07-21 what stopped it was a mayor happening
# to read the header and decline. Nothing else would have.
#
# The failure it prevents is unrecoverable and self-erasing: `kickstart -k`
# kills pogod's entire process tree, so a descendant that gets this far kills
# the fleet AND itself mid-run, with nobody left to report what happened.
#
# TWO independent signals, reported separately because they fail separately:
#
#   1. Process ancestry — the walk the header describes. Authoritative when the
#      chain is intact.
#   2. The POGO_AGENT_* environment marker pogod stamps on every agent it
#      spawns. Load-bearing precisely where (1) goes blind: a detached or
#      backgrounded grandchild whose intermediate parent has exited is
#      REPARENTED to launchd, and an ancestry walk from there finds no pogod
#      while the caller is still, in every way that matters, in the fleet.
#
# Deliberately NOT wired to `check`, which the usage block promises NEVER acts:
# it is a read-only drift report, it is how the fleet notices it is stale, and
# blinding the fleet to its own drift is not what this guard is for. The hazard
# is exclusively `redeploy`, and that is where the guard sits — on cmd_redeploy's
# first line, ahead of every other precondition, so no invocation reaches the
# drain, the build, or the kickstart without passing it.
#
# There is no override flag, by design. A flag that lets the forbidden caller
# proceed reduces this to the prose it replaces.

# ps_parent PID — prints "PPID COMM" for PID, or nothing if PID is unknown.
# The single seam onto the process table, isolated so the ancestry walk above it
# can be exercised against a synthetic tree with no processes to spawn (and, in
# particular, with no pogod to be a descendant of). Overridden wholesale by the
# unit test; never called with anything but a numeric pid.
ps_parent() {
    ps -o ppid=,comm= -p "$1" 2>/dev/null | sed 's/^ *//'
}

# pogod_ancestor [PID] — walks up the parent chain from PID (default: this
# process) and prints "PID COMM" of the first pogod ancestor. Returns 0 when one
# is found, 1 when the walk reaches the root without seeing one.
#
# Matches on the basename of COMM: ps reports pogod as the absolute path it was
# exec'd from (/Users/daniel/go/bin/pogod), which varies per machine and per
# sandbox, while the basename does not.
#
# The depth cap is a termination guarantee, not a policy: this walk must not be
# able to hang the deploy path even if the process table hands it a cycle.
pogod_ancestor() {
    local pid="${1:-$$}" depth=0 parent comm self=true
    while [ "$depth" -lt 64 ]; do
        depth=$((depth + 1))
        # ps_parent yields this pid's PARENT and this pid's OWN comm, so the
        # chain is walked by stepping to the parent and reading its comm on the
        # next lap. The starting process is stepped over without being tested:
        # the question is ancestry, not identity.
        read -r parent comm <<<"$(ps_parent "$pid")"
        if ! $self && [ -n "${comm:-}" ] && [ "$(basename "$comm")" = "pogod" ]; then
            printf '%s %s' "$pid" "$comm"
            return 0
        fi
        self=false
        # Unknown pid, no parent, a non-numeric read, or the root: the chain
        # ends here and it ended without a pogod in it.
        case "${parent:-}" in ''|*[!0-9]*) return 1 ;; esac
        [ "$parent" -gt 1 ] || return 1
        pid="$parent"
    done
    return 1
}

# assert_out_of_band — refuse to redeploy from inside pogod's process tree.
#
# The message NAMES the remedy and not just the refusal, on purpose: an agent
# that hits a bare "refused" will reasonably conclude the deploy is broken and
# either escalate wrongly or start hunting for a way around the guard. The
# redeploy it was asked to run is legitimate; it is the CALLER that is wrong,
# and only saying so turns a dead end into a handoff.
assert_out_of_band() {
    local ancestor="" reason=""
    if ancestor="$(pogod_ancestor)"; then
        reason="this process is a descendant of pogod (pid ${ancestor%% *}, ${ancestor#* })"
    elif [ -n "${POGO_AGENT_NAME:-}" ]; then
        reason="this process is a pogod-spawned agent (POGO_AGENT_NAME=${POGO_AGENT_NAME}); its parent chain no longer shows pogod, which is what a detached or reparented agent looks like"
    else
        return 0
    fi

    err "refusing to redeploy: $reason"
    cat >&2 <<EOF

  A redeploy runs 'launchctl kickstart -k' on ${DAEMON_LABEL}, which kills
  pogod's ENTIRE process tree. Run from inside that tree, it would kill the
  fleet and this process along with it, mid-deploy, with nothing left running
  to report what happened.

  THE REDEPLOY IS LEGITIMATE. THE CALLER IS NOT.
  It must be performed OUT OF BAND — from a process pogod did not spawn:

    * Daniel, from his own terminal:   scripts/pogo-self-deploy redeploy
    * a launchd one-shot outside pogod's job (mg-6afa sequencing)

  If you are an agent and were asked to redeploy: you cannot, and no flag
  changes that. Hand it back — mail 'human' that pogod is ready for an
  out-of-band redeploy, and say which revision it is owed.

  'scripts/pogo-self-deploy check' is safe from here and never acts; use it to
  report the drift you were going to fix.

EOF
    exit 1
}

# ---------------------------------------------------------------------------
# Mail-check post-check (mg-de08)
# ---------------------------------------------------------------------------
# The bounce is the one moment the fleet's mail loop reliably breaks, so it is
# the one moment worth checking it. On 2026-07-17 a redeploy reaped five crew
# mail-check schedules as agent_gone; the fleet then looked healthy — scheduled,
# answering nudges, diagnosing clean — with no mail delivery for ~2h. Nobody
# noticed until an unrelated heartbeat happened to look stale.
#
# pogod now keeps EXPECTED agents' mail-checks across a restart (mg-de08 Part
# A), and diagnose reports a missing one RED (Part C). This is the third leg:
# an independent assertion, from outside pogod, on the exact event that
# triggers the failure. It reports; it never blocks the redeploy — the daemon
# is already up and running main by the time it runs, and a false alarm must
# not look like a failed deploy.
#
# The ASSEMBLED path below (verify_mail_checks_restored -> mail_check_ids ->
# live curl -> parse -> classify) is shown able to go RED by
# scripts/pogo-self-deploy_live_test.sh, which stands up a real pogod, lets its
# real GC reap real mail-checks, and asserts this code reports the loss (mg-c02d).
# The pure-function tests in pogo-self-deploy_test.sh do NOT cover that wiring.
# If you change anything in that chain, that live control is the one that matters.
#
# EVERYTHING HERE REASONS ABOUT NAMES, NEVER TALLIES (mg-ea3e). The first cut of
# this check compared counts and granted slack as a NUMBER of dead polecats, so
# a --force bounce that killed a polecat with no mail-check handed out an
# allowance no schedule had earned — and one REAL crew loss slid under it
# silently. Architect: "Slack computed as a COUNT of dead polecats rather than
# the SET of schedules that legitimately vanished is the same error shape as the
# original bug — reasoning about a number instead of an identity." Count
# arithmetic cannot tell you WHICH schedule went missing, and WHICH is the only
# question this check exists to answer. A silent miss in the detector, inside
# the detector built because a health signal could not tell "fine" from "gone".
# So: sets in, set difference, names out. If you find yourself adding an
# integer here, you are reintroducing the bug.

# extract_mail_check_ids — the SET of mail-check-* schedule ids in a
# /scheduler/schedules body on stdin, one per line, sorted. Pure: the parse half
# of mail_check_ids, split out so it is testable without a live daemon.
extract_mail_check_ids() {
    grep -o '"id":"mail-check-[^"]*"' | sed 's/^"id":"//; s/"$//' | LC_ALL=C sort -u
}

# extract_mail_check_ids_for_agents NAMES — from a /scheduler/schedules body on
# stdin, the mail-check ids ADDRESSED TO any agent named in NAMES (one name per
# line). Pure.
#
# Matches on the schedule's `agent` field, not on the id string, because that is
# the identity both ends already agree on: internal/agent/mailcheck.go registers
# a polecat's loop against its bare registry name — "the same identity the reap
# path matches on" — while the id is keyed on the work item id. An agent with no
# mail-check yields no id here, which is exactly the point: slack it never
# earned is slack it never gets.
extract_mail_check_ids_for_agents() {
    local names="$1" line agent
    [ -n "$names" ] || return 0
    # `|| [ -n "$line" ]` is load-bearing: the body's LAST object carries no
    # trailing newline, so a bare `read` sets $line and then returns 1, and the
    # loop drops it. That silently forgives whichever schedule sorts last — a
    # miss in the detector, found only by an assertion that named a schedule the
    # daemon really emitted last.
    sed 's/},{/}\n{/g' | while IFS= read -r line || [ -n "$line" ]; do
        case "$line" in *'"id":"mail-check-'*) ;; *) continue ;; esac
        agent="$(printf '%s' "$line" | json_str agent)"
        [ -n "$agent" ] || continue
        printf '%s\n' "$names" | grep -qxF "$agent" || continue
        printf '%s' "$line" | json_str id
    done | LC_ALL=C sort -u
}

# snapshot_polecat_names — the names of every polecat in an /agents/drain
# snapshot on stdin, one per line. Pure. These are the identities a forced
# bounce killed; they are what the slack set is looked up BY.
snapshot_polecat_names() {
    sed 's/},{/}\n{/g' | grep -o '"name":"[^"]*"' | sed 's/^"name":"//; s/"$//'
}

# schedules_body — the raw /scheduler/schedules body. Returns 1 (and prints
# nothing) when pogod cannot be reached, so callers can tell "unreachable" from
# "reachable, and it holds nothing" — different facts that must never compare
# equal. Reporting an unreachable daemon as an empty fleet would announce the
# entire fleet lost; reporting it as OK would make this check decoration.
schedules_body() {
    local body
    body="$(curl -sf --max-time 5 "$(base_url)/scheduler/schedules" 2>/dev/null)" || return 1
    [ -n "$body" ] || return 1
    printf '%s' "$body"
}

# mail_check_ids — the SET of mail-check-* ids pogod currently holds, one per
# line. Echoes the "?" sentinel and returns 1 when pogod is unreachable.
#
# The sentinel is load-bearing. Under the old count this role was played by an
# empty string, which worked only because "" is not a number. A set has no such
# luck: "" is a perfectly good EMPTY SET. So unreachable gets an explicit mark —
# "?", the same sentinel this script already uses for an unknown polecat count —
# and empty is left free to mean what it says.
mail_check_ids() {
    local body
    body="$(schedules_body)" || { echo "?"; return 1; }
    printf '%s' "$body" | extract_mail_check_ids
}

# expected_lost_mail_checks PRE_BODY SNAPSHOT -> the SET of mail-check ids whose
# loss the forced bounce EXPLAINS, one per line.
#
# A schedule qualifies only if it (a) belongs to a polecat the bounce killed and
# (b) really existed before the bounce. Both halves come from names: the dead
# polecats' names out of the pre-kickstart drain snapshot, the schedules out of
# the pre-kickstart schedule body. Nothing is inferred from how MANY polecats
# died — a bounce that kills three polecats holding one mail-check between them
# excuses exactly one schedule, and it can say which.
expected_lost_mail_checks() {
    local body="$1" snapshot="$2" names
    names="$(printf '%s' "$snapshot" | snapshot_polecat_names)"
    printf '%s' "$body" | extract_mail_check_ids_for_agents "$names"
}

# missing_mail_checks PRE POST SLACK -> the SET of ids that vanished unexplained.
# Pure set arithmetic: PRE - (POST + SLACK). Each argument is a newline-separated
# set of ids. This is the whole check.
missing_mail_checks() {
    LC_ALL=C comm -23 \
        <(printf '%s\n' "$1" | sed '/^$/d' | LC_ALL=C sort -u) \
        <(printf '%s\n%s\n' "$2" "$3" | sed '/^$/d' | LC_ALL=C sort -u)
}

# classify_mail_check_restore PRE POST SLACK -> ok | unknown | missing:<ids>
#
# PRE and POST are SETS of mail-check ids (newline-separated); "?" means the
# daemon could not be read. SLACK is the SET of ids whose loss is EXPECTED — the
# schedules the --force-killed polecats really did take with them. They are
# reaped on purpose, so calling them damage would cry wolf on every forced
# deploy; but slack is granted per NAMED schedule, so it can only ever excuse
# the schedule it names.
#
# Ids in POST that were never in PRE are "ok": the crew re-registering, or a
# polecat spawning, both legitimately add. This check only ever asserts that
# mail-checks were not silently LOST.
classify_mail_check_restore() {
    local pre="$1" post="$2" slack="${3:-}" missing
    # Test each side SEPARATELY for the unreachable sentinel — an unreadable
    # daemon on either end is unknown, and must never be differenced against a
    # real set as though "?" were an id.
    [ "$pre" = "?" ] && { echo "unknown"; return; }
    [ "$post" = "?" ] && { echo "unknown"; return; }
    [ "$slack" = "?" ] && { echo "unknown"; return; }
    missing="$(missing_mail_checks "$pre" "$post" "$slack")"
    if [ -z "$missing" ]; then
        echo "ok"
    else
        echo "missing:$(printf '%s' "$missing" | tr '\n' ' ' | sed 's/ *$//')"
    fi
}

# set_size — how many ids are in a newline-separated set. For REPORTING only:
# the verdict is reached by name, and the count is a courtesy to the reader.
set_size() { printf '%s' "$1" | sed '/^$/d' | grep -c . ; }

# verify_mail_checks_restored PRE SLACK — poll the post-bounce SET and report.
# PRE and SLACK are newline-separated sets of mail-check ids ("?" for PRE when
# the pre-bounce daemon could not be read). Polls because the new pogod loads
# its schedules from disk moments after the port answers; it is not an "agents
# re-register in time" race (Part A means nothing has to re-register), just
# startup ordering.
verify_mail_checks_restored() {
    local pre="$1" slack="${2:-}" deadline verdict post
    if [ "$pre" = "?" ]; then
        log "mail-check post-check: SKIPPED (could not read mail-checks before the bounce)"
        return 0
    fi
    deadline=$(( $(date +%s) + MAIL_CHECK_TIMEOUT ))
    while :; do
        post="$(mail_check_ids)"
        verdict="$(classify_mail_check_restore "$pre" "$post" "$slack")"
        [ "$verdict" = "ok" ] && break
        [ "$(date +%s)" -ge "$deadline" ] && break
        sleep 3
    done
    case "$verdict" in
        ok)
            log "mail-check post-check: OK — $(set_size "$post") mail-check schedule(s) present (pre-bounce $(set_size "$pre"), expected loss $(set_size "$slack"))"
            if [ -n "$slack" ]; then
                log "  expected loss (force-killed polecats' own loops): $(printf '%s' "$slack" | tr '\n' ' ')"
            fi
            ;;
        unknown)
            log "mail-check post-check: UNKNOWN — could not read schedules from the new pogod"
            log "  verify by hand: pogo schedule list | grep mail-check"
            ;;
        missing:*)
            local lost="${verdict#missing:}"
            err "mail-check post-check: FAILED — $(printf '%s' "$lost" | wc -w | tr -d ' ') mail-check schedule(s) LOST across the bounce"
            err "  LOST: $lost"
            err "  pre-bounce $(set_size "$pre"), now $(set_size "$post"), expected loss $(set_size "$slack") (mg-de08)"
            err "  the fleet's mail loop is degraded and WILL LOOK HEALTHY. Diagnose:"
            err "    pogo schedule list | grep mail-check"
            err "    pogo agent diagnose <name>    # reports no_mail_loop for an agent with no loop"
            err "  restore by nudging the affected agents to re-register their mail-check."
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Revision sources (the three axes of drift)
# ---------------------------------------------------------------------------

# THE STAMP IS EVIDENCE, NOT TRUTH (mg-8f09). Every axis below reports what a
# binary CLAIMS about its own provenance, and a claim has three failure modes
# this check must keep apart, because they owe three different actions:
#
#   present & ours    — a commit that exists in $REPO. Comparable to main.
#   ABSENT            — no vcs stamp at all. NOT comparable to anything.
#   present & FOREIGN — a real commit, from a DIFFERENT repo. NOT comparable.
#
# The old code collapsed all three into a bare string and compared it to MAIN.
# That is why it could only ever say "behind main" — a claim about ANCESTRY it
# had not measured and, for the last two cases, could not measure. mg-49bc read
# that output and concluded "stale dirty build"; the truth was a foreign repo's
# HEAD (see the FOREIGN STAMP note in classify_drift). A verdict phrased in a
# vocabulary the check cannot actually support sends the reader somewhere else.
#
# So each source distinguishes its OWN kinds of absence, with sentinels that
# can never collide with a hex revision. Two absences that mean different things
# must not arrive here as the same empty string — that is the mg-de08 defect
# (absence of evidence read as evidence), and it is the one this file is for.
REV_UNSTAMPED='<unstamped>'     # binary is there; it carries NO vcs stamp
REV_MISSING='<missing>'         # binary is not on disk at all
REV_UNREACHABLE='<unreachable>' # pogod is not answering /version

# running: the revision of the LIVE pogod process, self-reported via /version.
# Must come from the process, not `go version -m` on disk: `go install` rewrites
# the on-disk binary underneath a live daemon, so the file's revision diverges
# from the running one the instant a rebuild happens.
#
# UNREACHABLE and UNSTAMPED are different answers: a daemon that will not talk
# owes a restart, a daemon that talks but cannot say what it is owes an
# investigation. Reporting both as "" made them one state.
running_rev() {
    local body
    body="$(curl -sf --max-time 5 "$(base_url)/version" 2>/dev/null)" \
        || { echo "$REV_UNREACHABLE"; return 0; }
    local rev; rev="$(printf '%s' "$body" | json_str revision)"
    if [ -n "$rev" ]; then echo "$rev"; else echo "$REV_UNSTAMPED"; fi
}

# DEPLOYED_CMDS: every binary this deploy owns, as `go install` package paths.
# The CLI is here because it is not optional cargo: `pogo` is the operator's only
# interface to the daemon, and a `pogo` older than the `pogod` it talks to is a
# protocol mismatch waiting to happen (mg-49bc). They move together or not at all
# — which is why the list lives at the top and every path below iterates it
# rather than naming a binary.
DEPLOYED_CMDS=(pogod pogo)

# installed_bin: where a deployed binary lives on disk.
installed_bin() {
    local name="$1"
    if [ -n "${POGO_GOBIN:-}" ]; then echo "$POGO_GOBIN/$name"; return; fi
    local gobin; gobin="$(go env GOBIN 2>/dev/null)"
    if [ -n "$gobin" ]; then echo "$gobin/$name"; return; fi
    echo "$(go env GOPATH 2>/dev/null)/bin/$name"
}
# installed: the revision baked into an on-disk ~/go/bin/<name> binary.
#
# The old contract was "empty when the binary is absent OR carries no stamp",
# justified as: empty never equals MAIN, so it classifies as a build owed rather
# than passing as "matches". That reasoning is CORRECT for a missing binary and
# WRONG for an unstamped one, and it fused the two cases into one string:
#
#   MISSING   — no binary. A build genuinely IS owed, and a build fixes it.
#   UNSTAMPED — a binary, built from a tree Go could not read VCS info for. A
#               build is NOT owed and a build does NOT fix it: the rebuild is
#               unstamped too, so it still "!= MAIN", so the drift never clears.
#               "Never equals MAIN" stops being a safe default the moment it
#               becomes permanent — it is a reconcile loop against an artifact
#               that is not broken, which is the exact thing this file's header
#               says a drift check must never start.
#
# Keeping them apart is what lets classify_drift owe a build for the first and
# refuse for the second.
installed_rev() {
    local bin; bin="$(installed_bin "$1")"
    [ -x "$bin" ] || { echo "$REV_MISSING"; return 0; }
    local rev
    rev="$(go version -m "$bin" 2>/dev/null | sed -n 's/.*vcs.revision=\([0-9a-f]*\).*/\1/p' | head -1)"
    if [ -n "$rev" ]; then echo "$rev"; else echo "$REV_UNSTAMPED"; fi
}

# rev_in_repo — does $REPO actually contain this commit? This is the whole
# foreign-stamp test, and it is re-derivable by hand: `git -C $REPO cat-file -e
# <rev>^{commit}`. A stamp naming a commit no ancestor query can even resolve is
# not "behind"; it is from somewhere else. Stubbed by the unit tests, which
# exercise the staleness axis with symbolic revisions.
rev_in_repo() {
    git -C "${REPO:-}" cat-file -e "${1}^{commit}" 2>/dev/null
}

# Revisions that are not comparable to MAIN at all — the sentinels above.
rev_is_sentinel() {
    case "$1" in
        "$REV_UNSTAMPED"|"$REV_MISSING"|"$REV_UNREACHABLE"|"") return 0 ;;
        *) return 1 ;;
    esac
}

# main: what the repo says SHOULD run (the deploy ref's HEAD).
main_rev() {
    git -C "$REPO" rev-parse "$DEPLOY_REF" 2>/dev/null
}

# ---------------------------------------------------------------------------
# Repo resolution — build from a known-good local checkout of the pogo source.
# Precedence: --repo / $POGO_REPO > the checkout this script lives in (when it
# is the pogo module) > error. The driver refuses to guess.
# ---------------------------------------------------------------------------
resolve_repo() {
    if [ -n "$REPO" ]; then
        git -C "$REPO" rev-parse --git-dir >/dev/null 2>&1 || { err "repo path '$REPO' is not a git repo"; exit 2; }
        return
    fi
    local self_dir top
    self_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    top="$(git -C "$self_dir" rev-parse --show-toplevel 2>/dev/null)"
    if [ -n "$top" ] && [ -f "$top/go.mod" ] && grep -q '^module github.com/drellem2/pogo$' "$top/go.mod" 2>/dev/null; then
        REPO="$top"
        return
    fi
    err "cannot resolve the pogo source repo; pass --repo PATH or set POGO_REPO"
    exit 2
}

# ---------------------------------------------------------------------------
# Drift computation
# ---------------------------------------------------------------------------
RUNNING="" ; INSTALLED="" ; INSTALLED_CLI="" ; MAIN=""
compute_drift() {
    RUNNING="$(running_rev)"
    INSTALLED="$(installed_rev pogod)"
    INSTALLED_CLI="$(installed_rev pogo)"
    MAIN="$(main_rev)"
}

# The CLI has no `running` axis — `pogo` is a short-lived process, so there is
# nothing to be stale except the binary on disk. That asymmetry is why it gets a
# row and not a column: installed-vs-main is the whole question for it.
print_drift() {
    echo "revision drift (repo: $REPO, ref: $DEPLOY_REF)"
    printf '  running        : %s\n' "$(annotate_rev "${RUNNING:-$REV_UNREACHABLE}")"
    printf '  installed pogod: %s\n' "$(annotate_rev "${INSTALLED:-$REV_MISSING}")"
    printf '  installed pogo : %s\n' "$(annotate_rev "${INSTALLED_CLI:-$REV_MISSING}")"
    printf '  main HEAD      : %s\n' "${MAIN:-<unknown>}"
}

# annotate_rev — print a revision with what we know ABOUT it. A bare hash in the
# report tells the reader nothing about whether it is even this repo's hash, and
# that missing word is what mg-49bc had to guess at.
annotate_rev() {
    local rev="$1"
    case "$rev" in
        "$REV_UNSTAMPED")   echo "<no vcs stamp — provenance UNKNOWN>"; return ;;
        "$REV_MISSING")     echo "<none on disk>"; return ;;
        "$REV_UNREACHABLE") echo "<unreachable — pogod not answering /version>"; return ;;
    esac
    if rev_in_repo "$rev"; then echo "$rev"; else echo "$rev  <FOREIGN — no such commit in $REPO>"; fi
}

# The three axes as "label:revision" pairs. One list, so a new axis cannot be
# added to the staleness check and forgotten by the provenance check.
drift_axes() {
    printf '%s\n' "running pogod:$RUNNING" "installed pogod:$INSTALLED" "installed pogo:$INSTALLED_CLI"
}

# Names the axes whose binary carries no vcs stamp at all.
unstamped_axes() {
    local line out=""
    while IFS= read -r line; do
        [ "${line#*:}" = "$REV_UNSTAMPED" ] && out="${out:+$out, }${line%%:*}"
    done < <(drift_axes)
    echo "$out"
}

# Names the axes whose stamp is a real revision that this repo has never heard
# of, quoting the claimed revision — the operator must be able to see WHAT was
# claimed, not just that something was wrong.
foreign_axes() {
    local line rev out=""
    while IFS= read -r line; do
        rev="${line#*:}"
        rev_is_sentinel "$rev" && continue
        rev_in_repo "$rev" || out="${out:+$out; }${line%%:*} claims $(short "$rev")"
    done < <(drift_axes)
    echo "$out"
}

# Names the binaries whose installed revision is behind main, for the operator
# who has to read WHY a build is owed.
stale_bins() {
    local out=""
    [ "$INSTALLED" != "$MAIN" ] && out="pogod"
    [ "$INSTALLED_CLI" != "$MAIN" ] && out="${out:+$out, }pogo"
    echo "$out"
}

# Sets NEEDS_BUILD / NEEDS_RESTART / owed-action string. Reports; never acts.
NEEDS_BUILD=false ; NEEDS_RESTART=false ; ACTION=""
classify_drift() {
    NEEDS_BUILD=false ; NEEDS_RESTART=false
    if [ -z "$MAIN" ]; then ACTION="cannot classify: main HEAD unknown"; return 1; fi

    # THE PROVENANCE GATE (mg-8f09) — runs BEFORE any comparison to MAIN,
    # because a comparison to MAIN is only meaningful once we know the thing we
    # are comparing is a commit from this repo. Both branches below REFUSE
    # (return 1) rather than owe a build: a build is the answer to "behind",
    # and neither of these is behind. Refusing is also the safe direction — the
    # caller leaves the old pogod running and dispatching, which is the correct
    # resting state for "we do not know what is deployed".
    local unstamped; unstamped="$(unstamped_axes)"
    if [ -n "$unstamped" ]; then
        # THE POST-mg-2ce4 WORLD. Once polecat worktrees move out of the ~/.pogo
        # repo, Go finds no VCS to read and stamps NOTHING. Absent beats false —
        # but absent must not read as clean, and it must not read as "behind"
        # either. Both are claims about a binary that has told us nothing.
        # The fleet already paid for this lesson once: the mg-de08 reap
        # concluded death from two absences. Absence of evidence is not
        # evidence, and a drift check is the last place that rule may lapse.
        ACTION="UNKNOWN PROVENANCE: $unstamped — NO vcs stamp. This is not a clean box and it is not a stale one; the binary has told us nothing. Expected a commit from $DEPLOY_REF (HEAD $(short "$MAIN")) in ${REPO:-<unresolved>}. A rebuild will NOT clear this — an unstamped binary rebuilds unstamped. Verify: go version -m \$(command -v pogod) | grep vcs."
        return 1
    fi

    local foreign; foreign="$(foreign_axes)"
    if [ -n "$foreign" ]; then
        # THE mg-49bc CORRECTION, made mechanical. A stamp naming a commit that
        # does not exist in $REPO is not stale and is not dirty — it is from
        # another repo entirely, and no amount of "git log main" will explain
        # it. Name BOTH sides so the verdict can be re-derived from its own
        # output with one cat-file, instead of re-investigated from scratch.
        ACTION="FOREIGN STAMP: $foreign — no such commit in ${REPO:-<unresolved>}. Expected a commit from $DEPLOY_REF (HEAD $(short "$MAIN")). This binary was built against a DIFFERENT repository; its revision (and any vcs.modified=true it reports) describes that repo, not this one. Verify: git -C ${REPO:-<repo>} cat-file -e <rev>^{commit}"
        return 1
    fi
    # A build is owed if ANY deployed binary is behind main — not just pogod.
    # Reading only pogod here is what let the CLI sit three days stale while this
    # very function reported "clean": the daemon matched main, so nothing looked
    # owed, and the drift check could not see the drift it was there to catch
    # (mg-ddf1). A check blind to half of what it installs reports health it has
    # not measured.
    { [ "$INSTALLED" != "$MAIN" ] || [ "$INSTALLED_CLI" != "$MAIN" ]; } && NEEDS_BUILD=true
    [ "$RUNNING"  != "$MAIN" ] && NEEDS_RESTART=true
    if ! $NEEDS_BUILD && ! $NEEDS_RESTART; then
        ACTION="clean — running == installed (pogod, pogo) == main; nothing owed"
    elif ! $NEEDS_BUILD; then
        # A rebuild already happened; only a restart bounces the fleet.
        ACTION="RESTART owed (no go install): installed already matches main, running is stale"
    elif ! $NEEDS_RESTART; then
        # The case the old classifier could not express, and today's actual
        # state: pogod is current and running main, and the CLI is stale anyway.
        ACTION="BUILD owed (no restart): running pogod is main, but installed $(stale_bins) behind main"
    elif [ "$RUNNING" = "$INSTALLED" ] && [ "$INSTALLED" != "$MAIN" ]; then
        ACTION="BUILD + RESTART owed: running == installed, both behind main"
    else
        ACTION="BUILD + RESTART owed: running/installed/main all differ ($(stale_bins) behind)"
    fi
    return 0
}

# ---------------------------------------------------------------------------
# check — report only, never act
# ---------------------------------------------------------------------------
cmd_check() {
    resolve_repo
    compute_drift
    print_drift
    classify_drift || { echo "action    : $ACTION"; return 1; }
    echo "action    : $ACTION"
    echo
    echo "(report only — 'pogo-self-deploy redeploy' performs the guarded rebuild+restart)"
}

# ---------------------------------------------------------------------------
# redeploy — guarded rebuild + restart
# ---------------------------------------------------------------------------
confirm() {
    $ASSUME_YES && return 0
    if [ ! -t 0 ]; then
        err "refusing to redeploy non-interactively without --yes (fleet-wide bounce)"
        exit 3
    fi
    printf 'Redeploy pogod (this WILL bounce the whole fleet)? [y/N] '
    read -r ans
    case "$ans" in y|Y|yes|YES) return 0 ;; *) log "aborted by user"; exit 0 ;; esac
}

# POST a drain state ({"draining":<bool>}) and echo the HTTP status code so the
# caller can tell an ANSWERED-but-missing endpoint (404, bootstrap) apart from a
# genuinely-unreachable pogod. curl (no -f) writes "000" for connection
# refused / DNS / timeout, so a numeric-but-non-2xx code always means the server
# answered. Kept curl-only on purpose — no jq, no extra hop (see file header).
drain_post() {
    local state="$1"
    curl -s -o /dev/null -w '%{http_code}' --max-time 5 \
        -X POST "$(base_url)/agents/drain" \
        -H 'Content-Type: application/json' -d "{\"draining\":${state}}" 2>/dev/null
}

# ---------------------------------------------------------------------------
# Drain restore (mg-8b48)
# ---------------------------------------------------------------------------
# `drain_post true` is a MUTATION OF ANOTHER PROCESS'S STATE, and until this
# trap existed it had no guaranteed undo. Every exit between enabling drain and
# the kickstart left the OLD pogod up with draining=true — dispatching NO
# polecats, fleet-wide, until a human noticed and restarted it. do_build's four
# exits all sit in that window, and the dirty-tree one fires on a condition a
# human creates by accident. Nothing goes red when it happens: pogod is up, the
# port answers, crew keep answering mail, so every health signal stays green
# while the fleet quietly stops doing work. Unattended at 03:00 that is a worse
# outcome than a missed deploy (mg-46a4 §5b).
#
# exit 5 (kickstart) and exit 8 (verify) LOOK like they are in the window and are
# not: by then the old process is gone, and a landed kickstart resets draining to
# its zero value (internal/agent/agent.go). That is luck of zero-value
# initialisation, not a restore path — do not lean on it, and do not mistake it
# for coverage of the exits above.
#
# RESTORE THE PRIOR VALUE, NEVER A HARD false. If drain was already on for an
# unrelated reason, forcing false asserts a state instead of restoring one, and
# that is the same bug wearing a different hat: this deploy would switch
# dispatch back on underneath whoever turned it off.
DRAIN_PRIOR=""     # draining as it was BEFORE this run touched it: true|false|?
DRAIN_ARMED=false  # true only between "we may have enabled drain" and the kickstart

# drain_state — the live draining flag: "true" | "false" | "?" when unreadable.
# "?" is the same unreachable sentinel the mail-check set uses, and for the same
# reason: "could not read it" and "it is off" are different facts, and restoring
# a value we never read is an assertion, not a restore.
drain_state() {
    local body v
    body="$(curl -sf --max-time 5 "$(base_url)/agents/drain" 2>/dev/null)" || { echo "?"; return 1; }
    v="$(printf '%s' "$body" | json_bool draining)"
    case "$v" in true|false) echo "$v" ;; *) echo "?"; return 1 ;; esac
}

# restore_drain — the EXIT trap body. Puts dispatch back the way we found it on
# ANY exit path while armed: the four do_build exits, an unexpected error under
# set -u, and Ctrl-C/SIGTERM (INT/TERM are trapped too, since a human aborting a
# deploy mid-drain leaves exactly the same outage as a failed build).
#
# Deliberately NOT self-healing-by-accident: it reports what it did, and reports
# LOUDLY when it could not, because a failed restore IS the outage this exists to
# prevent and the operator needs the one command that fixes it.
restore_drain() {
    local code=$? want st
    $DRAIN_ARMED || return
    DRAIN_ARMED=false   # a restore is attempted exactly once
    want="$DRAIN_PRIOR"
    if [ "$want" != "true" ] && [ "$want" != "false" ]; then
        err "drain restore: pre-deploy drain state was never read; ASSUMING dispatch was enabled"
        err "  (this ASSERTS draining=false rather than restoring a value — verify by hand if drain was intentionally on)"
        want=false
    fi
    log "restoring dispatch to its pre-deploy state (draining=$want) — deploy exited $code before the kickstart"
    st="$(drain_post "$want")"
    case "$st" in
        2??) log "dispatch restored: draining=$want" ;;
        *)   err "drain restore FAILED (HTTP ${st:-000}) — pogod may STILL be draining and dispatching NO polecats."
             err "  The fleet will look healthy and do nothing. Restore by hand:"
             err "    curl -X POST $(base_url)/agents/drain -H 'Content-Type: application/json' -d '{\"draining\":$want}'"
             ;;
    esac
}

# ---------------------------------------------------------------------------
# The external sink (mg-f206) — how a run that DOES NOTHING gets noticed
# ---------------------------------------------------------------------------
# THE FAILURE THIS COVERS. `redeploy` fails CLOSED when the drain times out with
# polecats still working: it restores dispatch and exits 7 without deploying,
# rather than killing live work. Attended that is correct and self-reporting —
# the human who ran it is standing there and reads the refusal. Unattended at
# 03:00 it is a deploy that SILENTLY NEVER HAPPENS. Nothing is broken, so nothing
# goes red: pogod is up, the port answers, the fleet dispatches, every light is
# green — and we believe we track main while not tracking it, indefinitely. The
# absence of a deploy produces no signal. That is this fleet's defect (mg-de08,
# mg-8b48, mg-0b77) at the OUTCOME layer.
#
# "FAILS CLOSED" IS NOT "FAILS VISIBLY". They are as different as *unreachable*
# and *zero*, which is the distinction the rest of this file is built around.
#
# WHAT LOUD MEANS HERE, AND WHY IT IS NOT A LOG LINE. Architect's ruling: loud
# must be OBSERVABLE FROM OUTSIDE THE THING THAT FAILED. A louder err line into
# an unread log is the same silence with more characters — this script's stderr
# at 03:00 goes to a file nobody opens unless already suspicious, which is the
# state we are trying to cause, not assume. The shape is not invented here:
# sentineldrift.go and orphan.go (mg-0b77) both answer it with a durable event
# PLUS a mail to the coordinator, and this follows that precedent rather than
# inventing a second notion of loud.
#
# WHY THE MAIL IS VERIFIED AND THE EVENT IS NOT COUNTED. mg-0b77's sink is
# best-effort: a failed `mg` shell-out lands in a log line, so the sink can rot
# (a renamed flag, a moved binary) and go silent exactly like the thing it
# reports on. Its answer was a positive control proving the assembled sink fires
# — the ask this ticket inherits, and the live control does that. But a sink that
# fires at most once per run can do better than be proven in a lab: it can READ
# ITS OWN MESSAGE BACK OUT OF THE RECIPIENT'S MAILBOX and refuse to claim a
# delivery it cannot see. That is not proof it CAN fire; it is observation that
# it DID. `pogo events emit` cannot be held to that standard — it is documented
# best-effort and ALWAYS exits 0, so its status cannot distinguish a landed event
# from a dropped one. So it is emitted for mg and the digest, and deliberately
# NOT counted toward delivery. Counting it would be exactly the lie this script
# refuses everywhere else: inferring a fact from a channel that cannot report it.
#
# THE RESIDUAL, STATED HONESTLY. If every outbound channel is dead, this run is
# silent and no code here can fix that — a process whose every channel is gone
# cannot report that its channels are gone. What is bounded is the far more
# likely case: one channel wrong (a renamed coordinator, an unwritable box)
# while another works. Hence two recipients and a readback, not one blind send.
#
# The coordinator's mailbox is not addressed by a name we trust. This default is
# a CLAIM about config ([agents] coordinator) and it decays like any other — so
# it is CHECKED rather than believed: mg reports `mailbox_created` when a send
# invents the box, and for THIS recipient that is proof the name is wrong. The
# coordinator always has a mailbox by the time a nightly redeploy runs; if our
# send had to create one, we just filed the alert in a phantom nobody reads.
# (That is not hypothetical — this box carries a phantom mailbox today, minted by
# a mis-shelled recipient, and it is invisible precisely because it was silent.)
COORDINATOR="${POGO_COORDINATOR:-mayor}"

# MG — the ABSOLUTE path to the macguffin `mg`, resolved once by resolve_mg().
#
# BARE `mg` IS A TRAP, AND IT IS THE BUG THIS SINK WAS SILENTLY LOSING TO
# (mg-015f). On macOS, /usr/bin/mg is the Micro-Emacs text EDITOR. Under any
# PATH where /usr/bin precedes ~/go/bin — a login shell's reordered profile, or
# launchd's minimal PATH (/usr/bin:/bin:/usr/sbin:/sbin, which has NO ~/go/bin) —
# bare `mg` binds to that editor, not the macguffin tracker. Headless it panics
# ("standard input and output must be a terminal") and exits, so a bare-`mg`
# alert delivers NOTHING. The nightly redeploy runs in exactly that launchd
# context: a 03:00 stall alert would invoke the editor, panic, and fail closed
# and SILENT — the precise failure this whole sink exists to prevent.
#
# So every `mg` call in this deploy goes through "$MG", an absolute path to the
# go-installed macguffin binary. NOT a per-wrapper PATH export: that would only
# fix the launchers we happen to control and leaves the script PATH-fragile,
# which is worthless against a nightly launcher we do not control. An absolute
# path makes the deploy PATH-INDEPENDENT, which is the only thing that protects
# the nightly.
MG=""

# resolve_mg — set MG to the macguffin `mg`, or fail loudly. Never falls back to
# an UNVERIFIED bare `mg` (that could be the editor).
#
# It walks a list of candidate binaries and accepts the FIRST that passes a
# macguffin IDENTITY check. Two rules make this safe and PATH-independent:
#
#   1. IDENTITY, NOT EXISTENCE. /usr/bin/mg (the editor) satisfies -x and even
#      `command -v mg`, so locating a candidate never means trusting it. Every
#      candidate must self-identify as macguffin (its --help names "macguffin";
#      the editor's does not — it errors "illegal option -- -") before use. This
#      identity gate is the real safety property: the editor can appear anywhere
#      in the list and is always found-and-rejected, never invoked.
#
#   2. GOPATH CANDIDATES FIRST. The go-install bin dir is derived and tried
#      before any PATH lookup, so the production nightly — launchd's minimal PATH
#      with NO `go` and /usr/bin/mg (editor) ahead of ~/go/bin — resolves the
#      real ~/go/bin/mg without ever consulting PATH. That PATH-independence is
#      the whole point (mg-015f): a per-wrapper PATH export would only fix
#      launchers we control, and we do not control the nightly's.
#
# Deliberately NOT POGO_GOBIN: that overrides where THIS deploy INSTALLS pogod
# and pogo (its target dir, which the sink controls point at a throwaway). mg is
# not a deployed binary — it is a stable external tool macguffin `go install`s to
# the standard go bin dir.
resolve_mg() {
    local cand gobin gopath pathmg
    local -a cands=()
    gobin="$(go env GOBIN 2>/dev/null)"
    [ -n "$gobin" ] && cands+=("$gobin/mg")
    gopath="$(go env GOPATH 2>/dev/null)"
    [ -n "$gopath" ] && cands+=("$gopath/bin/mg")
    # `go` may be off PATH entirely (launchd's minimal PATH has no go), so the
    # env-var and conventional-default GOPATH cover the case where `go env` said
    # nothing. macguffin installs to $GOPATH/bin, default $HOME/go/bin.
    [ -n "${GOPATH:-}" ] && cands+=("$GOPATH/bin/mg")
    cands+=("$HOME/go/bin/mg")
    # LAST RESORT: a macguffin `mg` already on PATH — accepted ONLY if it passes
    # the identity check, so the editor at /usr/bin/mg is rejected here rather
    # than run. This rescues an isolated HOME (the live control sandboxes HOME to
    # isolate the mail STORE, which points every $HOME/go path at an empty tree
    # while the real macguffin binary sits on PATH). Production never reaches this
    # rung — its GOPATH candidate resolves first.
    pathmg="$(command -v mg 2>/dev/null)"
    [ -n "$pathmg" ] && cands+=("$pathmg")

    for cand in "${cands[@]}"; do
        [ -x "$cand" ] || continue
        "$cand" --help 2>/dev/null | grep -q 'macguffin' || continue
        MG="$cand"
        log "mg: resolved macguffin at $MG"
        return 0
    done

    err "mg: no macguffin 'mg' found among the go-install paths or PATH (tried: ${cands[*]})."
    err "mg: refusing bare 'mg' — on this OS that is /usr/bin/mg, the Micro-Emacs EDITOR, which satisfies 'command -v' but panics headless and delivers no alert (mg-015f)."
    return 1
}

# mail_alert RECIPIENT SUBJECT BODY_FILE
# Returns 0 ONLY when the message is READ BACK out of the recipient's mailbox.
# Every other path returns 1 and says which one it took: "we could not tell" and
# "it was delivered" must not collapse, here least of all.
#
# --body-file, not --body: the shell expands $VAR, backticks and $(cmd) inside
# --body="..." before mg ever sees them, and mg reports Delivered on the mangled
# string because it cannot tell it from one you typed (mg-8380). This body
# carries the operator's remedies; it must arrive as written.
mail_alert() {
    local to="$1" subject="$2" body_file="$3"
    local out id created
    if ! out="$("$MG" mail send "$to" --from=pogo-self-deploy \
                    --subject="$subject" --body-file "$body_file" --json 2>&1)"; then
        err "sink: mg mail send to '$to' failed: $out"
        return 1
    fi
    id="$(printf '%s' "$out" | json_str msg_id)"
    created="$(printf '%s' "$out" | json_bool mailbox_created)"
    if [ -z "$id" ]; then
        err "sink: mg mail send to '$to' exited 0 but named no msg_id: $out"
        return 1
    fi
    if [ "$created" = "true" ]; then
        err "sink: '$to' had NO mailbox — this send CREATED one, so the alert is sitting in a phantom box nobody reads"
        err "sink: the recipient name is wrong (POGO_COORDINATOR / [agents] coordinator), not the message"
        return 1
    fi
    # THE READBACK. --all, not the default: the coordinator is a live agent and
    # may read the mail between the send and this probe, which moves it to cur/
    # and out of an unread-only listing. Without --all a FAST reader would look
    # exactly like a lost message and we would escalate over a success.
    # -F: msg_ids are dotted, and we are matching a literal, not a pattern.
    if "$MG" mail list "$to" --all --json 2>/dev/null | grep -Fq "$id"; then
        return 0
    fi
    err "sink: mailed '$to' (msg_id=$id) but could not read it back — treating as UNDELIVERED"
    return 1
}

# alert_external EVENT_TYPE SUBJECT BODY [DETAILS_JSON]
# Returns 0 iff a mail was VERIFIED into a real mailbox, by any recipient.
alert_external() {
    local event_type="$1" subject="$2" body="$3" details="${4:-}"
    local bf rc=1
    local -a ev

    if ! bf="$(mktemp)"; then
        err "sink: cannot create a temp file for the alert body — mailing the subject alone"
        bf=""
    else
        printf '%s\n' "$body" > "$bf" || { err "sink: could not write the alert body"; : > "$bf"; }
    fi

    # Channel 1 — the durable event, for mg and the digest. Best-effort by the
    # bridge's own contract (always exits 0); see the header for why its silence
    # is not counted as delivery.
    if command -v pogo >/dev/null 2>&1; then
        ev=(events emit --type="$event_type" --agent=pogo-self-deploy)
        [ -n "$details" ] && ev+=(--details="$details")
        pogo "${ev[@]}" >/dev/null 2>&1 || true
    else
        err "sink: no 'pogo' on PATH — the $event_type event was not emitted (launchd hands jobs a minimal PATH; the nightly wrapper must set it)"
    fi

    # Channel 2 — the mail. The loud half, and the only one we verify.
    if [ -n "$bf" ] && mail_alert "$COORDINATOR" "$subject" "$bf"; then
        log "sink: alerted '$COORDINATOR' and read the message back out of the mailbox"
        rc=0
    elif [ -n "$bf" ] && mail_alert human "$subject" "$bf"; then
        err "sink: could not verify a mail to coordinator '$COORDINATOR' — escalated to 'human' instead"
        rc=0
    else
        err "sink: NO EXTERNAL ALERT WAS DELIVERED — neither '$COORDINATOR' nor 'human' could be reached."
        err "sink: this run is now as silent as it was before mg-f206; the $event_type event (if it landed) is the only trace."
        rc=1
    fi
    [ -n "$bf" ] && rm -f "$bf"
    return $rc
}

# alert_drain_stalled REASON LEFTOVER — the exit 7 sink.
#
# `leftover` is a COUNT or the "?" sentinel. "?" is carried into the mail
# verbatim — the operator must see "we could not count them", not a fabricated
# number — but it is not a JSON number, so the event's `leftover` is emitted as a
# STRING. Quoting it keeps both facts expressible in one field rather than making
# "?" masquerade as 0, which is the count-vs-unknown collapse this file exists to
# refuse (mg-76e5).
#
# REASON SELECTS THE STORY, AND IT HAS TO (mg-65b2). Exit 7 now has two causes,
# and they are different situations needing different reactions:
#
#   timeout — the fleet was BUSY at the deadline. Nothing is wrong; the deploy
#             just didn't happen. Ignore it once; investigate if it repeats.
#   unknown — the drain could not establish the fleet's state at all. Something
#             IS wrong (pogod went silent mid-drain, or its readout is
#             unreadable), and it wants a human now.
#
# Before this the body narrated the timeout unconditionally: "the drain waited
# ${DRAIN_TIMEOUT}s ... and N were still active at the deadline". Sent for an
# unknown, every clause of that is false — no deadline passed, nothing was
# counted — and the "ignore it once" advice is exactly wrong. An alert that
# invents a confident story about a state we admitted we could not read is this
# ticket's defect wearing the sink's hat, so the sink gets told which one it is
# rather than assuming.
alert_drain_stalled() {
    local reason="$1" leftover="$2"
    local subject preamble what verdict todo
    case "$reason" in
        unknown)
            subject="[deploy-stalled] nightly pogod redeploy did NOT deploy — FLEET STATE UNKNOWN"
            preamble="The fleet's state is UNKNOWN — this is not the routine busy-fleet stall.
Something stopped answering, and this run refused rather than guess. The
refusal is correct and nothing was destroyed, but the CAUSE is still there
and the next run will refuse the same way until a human looks."
            verdict="This IS worth looking at, unlike a plain drain timeout: the deploy did not
happen AND the reason it did not happen is itself a fault. Refusing was the
safe outcome, not a resolution."
            what="the drain could not establish whether any polecat is alive.
                pogod stopped answering its drain readout mid-drain, or answered
                something unreadable, and the on-disk polecat witness could not
                settle it either. Bouncing a fleet whose state is unknown can
                mint PERMANENT survivors — polecats setsid out of the process
                group, outlive kickstart -k, and go invisible to every future
                registry — so this run refused. Nothing was killed or deployed."
            todo="WHAT TO DO. Unlike a plain drain timeout, this one is NOT routine and does
not clear itself. Look now:
  - Is pogod alive and answering?  curl $(base_url)/agents/drain
  - If it is WEDGED but the fleet is idle, the redeploy is the repair and will
    proceed on its own once pogod answers — or force it: redeploy --force.
  - If polecats ARE live, let them finish; do NOT --force. It re-gates mg-0b77
    and mg-13a3, and 46a4 measured that --force neither waits nor reliably
    kills: kickstart -k kills the job's process group, and polecats setsid out.
  - 'pogo agent witness' reports what the on-disk witness can still see with
    pogod down. If it says the witness is missing or unreadable, that is the
    double absence that produced this alert — fix the witness first."
            ;;
        *)
            subject="[deploy-stalled] nightly pogod redeploy did NOT deploy — $leftover polecat(s) still active"
            preamble="Fleet is HEALTHY and dispatching. Nothing is broken. That is the problem:
this run failed CLOSED and produced no other signal, so the fleet is simply
NOT TRACKING main and every light stays green while it doesn't."
            verdict="This is NOT an emergency and NOT a bug. It is the safe outcome, reported —
the deploy simply did not happen and you would otherwise never learn that."
            what="the drain waited ${DRAIN_TIMEOUT}s for the fleet to quiesce and
                $leftover polecat(s) were still active at the deadline. Deploying
                past that means hard-bouncing live work, which needs --force, and
                --force is deliberately not armed on the nightly."
            todo="WHAT TO DO. Nothing, if this is a one-off: the fleet was busy at 03:00 and the
next run will deploy. It matters when it REPEATS — a nightly that stalls every
night has silently stopped tracking main, which looks identical to one that
succeeds every night. So:
  - Once:      ignore it.
  - Repeatedly: the fleet is never idle at 03:00, or a polecat is wedged and
               never finishing. Check for a stuck polecat, then either resolve it
               or move the window. Consider --drain-timeout.
  - Do NOT 'fix' this by adding --force. It re-gates mg-0b77 and mg-13a3 (read
    them first), and 46a4 measured that --force neither waits nor reliably kills:
    kickstart -k kills the job's process group and polecats setsid out of it."
            ;;
    esac
    alert_external deploy_stalled \
        "$subject" \
        "A pogod redeploy refused to deploy and exited WITHOUT changing anything.

$preamble

What happened:  $what
Deploy ref:     $DEPLOY_REF
Running pogod:  $(short "${RUNNING:-?}")
Installed pogod:$(short "${INSTALLED:-?}")
Installed pogo: $(short "${INSTALLED_CLI:-?}")
main:           $(short "${MAIN:-?}")
Dispatch:       RESTORED (the exit trap put back draining=${DRAIN_PRIOR:-?}).
                No polecat was killed. No worktree was touched. Nothing deployed.

$verdict

$todo

Redeploy by hand when the fleet is idle:
  scripts/pogo-self-deploy redeploy --yes" \
        "{\"leftover\":\"${leftover}\",\"reason\":\"${reason}\",\"drain_timeout\":${DRAIN_TIMEOUT},\"deploy_ref\":\"${DEPLOY_REF}\",\"outcome\":\"no_deploy\"}"
}

# Pure decision function (unit-tested): map the POST /agents/drain HTTP status
# to a drain-phase disposition. Echoes exactly one word:
#   drain      — 2xx: endpoint present, proceed to drain_wait
#   bootstrap  — 404: server answers but predates the drain endpoint (mg-cae1);
#                the one-time self-deploy chicken-and-egg (mg-065e)
#   down       — 000/empty: pogod not answering (connection refused / timeout)
#   error:<c>  — any other status; refuse rather than guess
classify_drain_precondition() {
    case "$1" in
        2??)     echo "drain" ;;
        404)     echo "bootstrap" ;;
        000|"")  echo "down" ;;
        *)       echo "error:$1" ;;
    esac
}

# drain_probe — GET the drain readout and echo BODY, then a final line carrying
# the HTTP status. One hop, two facts: the body we must parse and the status
# classify_drain_precondition needs to rule on it. Mirrors drain_post's `-w
# '%{http_code}'` trick, and for the same reason — curl (no -f) writes "000" for
# connection refused / DNS / timeout, so a numeric-but-non-2xx code always means
# the server answered.
#
# Deliberately NOT two calls. Fetching the body and then the status separately
# would let them describe different moments — a body from a live pogod and a
# status from a dead one — and the whole point of the caller is to stop treating
# two world-states as one.
drain_probe() {
    curl -s -w '\n%{http_code}' --max-time 5 "$(base_url)/agents/drain" 2>/dev/null
}

# witness_alive_count — consult the SECOND witness (mg-13a3) about whether any
# polecat is alive, WITHOUT pogod. Echoes a count and returns 0 when that count
# is a measurement; echoes "?" and returns 1 when the witness cannot answer.
#
# WHY A CLI HOP IN A CURL-AND-SED SCRIPT. The header's rule is "call only STABLE
# primitives; keep it dumb", and reading the JSON here with the seds above would
# obey its letter. It would break the rule that matters. "Alive" is not "the pid
# is in the file" — it is kill(pid,0) AND a `ps -o lstart=` identity match,
# because a bare pid is a false witness (pids get recycled). That test already
# exists, unit-tested, in ONE place, whose own doc names this caller: "if they
# ever disagreed about what 'our process is alive' means, the drain and the
# reaper would be reasoning about different fleets." A shell re-implementation
# would be a second definition of the word, free to drift silently — the same
# mistake as growing a private notion of "down" beside
# classify_drain_precondition, which the ruling on mg-65b2 forbade twelve lines
# up. So: one definition, reached over a process boundary.
#
# THE DEPENDENCY FAILS CLOSED, WHICH IS WHY IT IS TOLERABLE. `pogo` is a binary
# this script DEPLOYS, so leaning on it here is a real coupling. Every way it can
# fail — missing from PATH, too old to know the subcommand, broken — exits
# non-zero and lands on "?", i.e. REFUSE. A broken CLI cannot manufacture a
# confident zero, and that asymmetry is the whole reason this hop is safe. Note
# the consequence honestly: until a redeploy installs a `pogo` carrying `agent
# witness`, the down-branch below always refuses. That is the safe direction and
# --force is the escape, but it is a real change of behaviour on the first night.
#
# BOUND OF THE INSTRUMENT, STATED RATHER THAN GLOSSED. The witness only knows
# polecats spawned by a pogod carrying mg-13a3. A survivor of a PRE-witness pogod
# is invisible to it — exactly as it is to the registry — so a present witness can
# under-count. That is the same limit 13a3 shipped with, it shrinks to nothing as
# the box's pogod moves past that commit, and it is not a reason to prefer the
# unconditional zero this replaces.
witness_alive_count() {
    local out rc n msg
    # 2>&1 on purpose: on the happy path the command says nothing on stderr, and
    # on a sad one — an OLD `pogo` that answers this subcommand with cobra's
    # usage text rather than our JSON — the complaint is the only diagnostic
    # there is, and it belongs in the operator's log rather than /dev/null.
    out="$("$POGO_CLI" agent witness --json 2>&1)"; rc=$?
    # The reason as a sentence, falling back to whatever came out if it was not
    # our JSON at all (again: the old-CLI case).
    msg="$(printf '%s' "$out" | json_str error)"; msg="${msg:-$out}"
    case "$rc" in
        0)
            n="$(printf '%s' "$out" | json_num alive_count)"
            case "$n" in
                ''|*[!0-9]*)
                    err "witness: '$POGO_CLI agent witness' returned no readable alive_count: $msg"
                    echo "?"; return 1 ;;
            esac
            echo "$n"; return 0 ;;
        2)
            err "witness: $msg"
            echo "?"; return 1 ;;
        *)
            err "witness: cannot read the on-disk polecat witness (rc=$rc): $msg"
            echo "?"; return 1 ;;
    esac
}

# Poll the drain readout down to zero polecats. Echoes the final polecat count,
# or the "?" sentinel when the fleet's state could not be established.
#
#   rc 0 — quiesced. The fleet is idle and it is safe to bounce.
#   rc 1 — the deadline passed with polecats still active (echoes the count).
#   rc 2 — CANNOT TELL (echoes "?"). Refuse; --force overrides.
#
# WHY THIS IS NOT `count="${count:-0}"` ANY MORE (mg-65b2)
# --------------------------------------------------------
# It used to be. `curl -sf` yields an EMPTY body on any failure — refused
# connection, timeout, 5xx, a non-JSON body — json_num then yields empty, and
# `${count:-0}` rendered "I could not read it" as "there are zero polecats". The
# gate returned quiesced on the FIRST poll, without waiting at all, and the
# redeploy went on to kickstart -k over a live fleet: polecats setsid out of the
# process group and SURVIVE (mg-46a4, mg-61a0), holding worktrees and claims,
# invisible to the successor's registry forever. No --force required. Measured
# against a dead port, not inferred.
#
# The irony was exact and is worth keeping on the record: report_drain_complete,
# three lines down, was ALREADY honest — 935ce5f taught it to say "this is NOT a
# report that there are none — it is a report that we could not look" — while the
# function that DECIDES WHETHER TO BOUNCE still rendered the same absence as a
# confident zero. 0b77 fixed the report. It never touched the gate.
#
# THE FORK "FAIL OPEN OR FAIL CLOSED?" IS MALFORMED, AND BOTH RULERS REFUSED IT.
# Each is an attempt to pick a least-bad action for a state whose distinguishing
# information `${count:-0}` had already destroyed. The fix is not a better
# default for an unknown state; it is to STOP MAKING THE STATE UNKNOWN. Three
# parts, cheapest first:
#
#   1. A MISSING SAMPLE IS NOT A MEASUREMENT. This is a deadline-bounded poll: a
#      single transient curl failure means no data this tick, not a reading of
#      zero. So poll again. That alone covers most real occurrences — a >5s
#      response under load, a blip — and it needs no policy and no fork.
#   2. SUSTAINED SILENCE IS A REAL STATE CHANGE — and the classifier for it
#      already exists, pure and unit-tested, twelve lines up. Reuse it. Two
#      functions with private definitions of "down" is how this recurs.
#   3. THEN EACH BRANCH IS OBVIOUS. See the case below.
#
# UNREACHABLE IS NOT UNKNOWABLE. /agents/drain is a PROXY; the real question —
# "are there live polecats?" — stays observable when pogod dies, because mg-13a3
# persisted a second witness to disk for exactly this class of question. We just
# had not noticed the drain was asking it. So `down` consults the witness rather
# than guessing, and that is what dissolves the objection that refusing on an
# unreachable pogod blocks the repair at the moment it is needed: wedged+idle
# PROCEEDS (by right — the bounce IS the repair, and strands nothing that is not
# already stranded), wedged+live REFUSES. The gate blocks exactly when it should
# and never when it shouldn't.
DRAIN_UNREADABLE_LIMIT=3   # consecutive unreadable samples before it means something
DRAIN_UNREADABLE_SLEEP=2   # a blip is re-probed in seconds, not the 15s drain tick

drain_wait() {
    local deadline=$(( $(date +%s) + DRAIN_TIMEOUT ))
    local raw code body count disp live misses=0
    while :; do
        raw="$(drain_probe)"
        code="${raw##*$'\n'}"
        body="${raw%$'\n'*}"

        # A count is a MEASUREMENT only if the server answered 2xx AND the body
        # actually parsed. Anything else falls through to the missing-sample
        # path below — it must never reach the `-eq 0` test.
        count=""
        [ "$(classify_drain_precondition "$code")" = "drain" ] \
            && count="$(printf '%s' "$body" | json_num count)"

        case "$count" in
            ''|*[!0-9]*) ;;   # no sample this tick — handled below
            *)
                misses=0
                if [ "$count" -eq 0 ]; then echo 0; return 0; fi
                if [ "$(date +%s)" -ge "$deadline" ]; then echo "$count"; return 1; fi
                log "draining: $count polecat(s) still active — waiting..." >&2
                sleep 15
                continue ;;
        esac

        # --- (1) missing sample: poll again, conclude nothing ----------------
        misses=$(( misses + 1 ))
        if [ "$misses" -lt "$DRAIN_UNREADABLE_LIMIT" ]; then
            log "drain readout unreadable (http=${code:-000}, sample $misses/$DRAIN_UNREADABLE_LIMIT) — polling again" >&2
            if [ "$(date +%s)" -ge "$deadline" ]; then echo "?"; return 2; fi
            sleep "$DRAIN_UNREADABLE_SLEEP"
            continue
        fi

        # --- (2) sustained: classify it, with the classifier we already have -
        disp="$(classify_drain_precondition "$code")"
        case "$disp" in
            down)
                # (3) pogod is not answering. Ask the other witness.
                live="$(witness_alive_count)" || {
                    # DOUBLE ABSENCE — pogod silent AND the witness cannot
                    # answer. Genuinely unknown, and the one place where there
                    # is nothing left to consult. Fail closed; that is 13a3's
                    # thesis one layer up: never conclude "drained" from a
                    # SINGLE absence, and certainly not from two.
                    err "pogod is not answering AND the polecat witness could not be read"
                    err "this is a DOUBLE ABSENCE: nothing here knows whether polecats are alive."
                    err "refusing to bounce a fleet whose state is unknown. --force overrides."
                    echo "?"; return 2
                }
                if [ "$live" -eq 0 ]; then
                    log "pogod stopped answering, and the witness reports no live polecat" >&2
                    log "the fleet is idle: bouncing a wedged pogod strands nothing and IS the repair" >&2
                    echo 0; return 0
                fi
                err "pogod is not answering, but the witness reports $live live polecat(s)"
                err "bouncing now would mint PERMANENT survivors: they outlive kickstart -k"
                err "(they setsid out of the process group) and go dark forever — no registry"
                err "can ever see them again. Refusing. --force overrides."
                echo "?"; return 2 ;;
            *)
                # Reachable, but we cannot read what it said. A LIVE pogod with
                # an invisible count is exactly where bouncing destroys work,
                # and the witness cannot help: it does not know about polecats
                # this pogod holds in a registry we just failed to read. Refuse
                # rather than guess — --force already means "I know it's wedged,
                # bounce it anyway".
                err "pogod is answering (${disp}) but its drain readout is unreadable after $misses tries"
                err "refusing to bounce a LIVE pogod whose polecat count we cannot see. --force overrides."
                echo "?"; return 2 ;;
        esac
    done
}

# Echo one line per polecat that is alive but UNREACHABLE — witnessed processes
# with no registry entry (mg-0b77). Input: an /agents/drain snapshot.
#
# These are survivors of an EARLIER pogod restart. They are not in `count`, and
# so they are not what drain_wait polls to zero: a survivor is not drainable
# (there is no adopt path, and absence never heals), so counting one would block
# every future redeploy forever rather than fix anything. They are reported
# instead — the drain completes, it just stops claiming they do not exist.
unreachable_list() {
    # `|| [ -n "$line" ]` is load-bearing, not defensive noise — the same trap
    # extract_mail_check_ids_for_agents already documents above. The pipeline's
    # last record carries NO trailing newline (the body arrives via command
    # substitution, which strips them), and a bare `read` sets the variable but
    # returns non-zero at EOF, so the plain loop silently DROPS the last
    # survivor. With one survivor that is all of them: this function reports
    # nothing while looking like it worked — the exact silence mg-0b77 exists to
    # remove, rebuilt inside its own fix. Caught by its own test, not by review.
    printf '%s' "$1" \
        | sed -n 's/.*"unreachable":\[\(.*\)\].*/\1/p' \
        | sed 's/},{/}\n{/g' \
        | while IFS= read -r line || [ -n "$line" ]; do
            local n p w
            n="$(printf '%s' "$line" | json_str name)"
            p="$(printf '%s' "$line" | json_num pid)"
            w="$(printf '%s' "$line" | json_str work_item_id)"
            [ -z "$n" ] && continue
            echo "$n (pid=${p:-?}, work_item=${w:-unknown})"
        done
}

# Report the end of a successful drain HONESTLY. `count` reaching zero is a fact
# about pogod's in-memory REGISTRY, not about the machine, and the old message
# ("drain complete — 0 polecats active") asserted the second on the strength of
# the first — declaring completion over any polecat that outlived an earlier
# restart and is invisible to this registry forever (mg-0b77 / mg-46a4 §5a).
report_drain_complete() {
    local body errmsg leftovers n
    body="$(curl -sf --max-time 5 "$(base_url)/agents/drain" 2>/dev/null)"

    # This is a SECOND, independent fetch — drain_wait's success proves the
    # daemon answered 15s ago, not that it is answering now. An empty body means
    # we learned nothing, and "I could not ask" must never print as "none
    # unreachable": that is this ticket's own defect (absence of evidence
    # rendered as a positive claim about the world) reproduced inside its fix.
    if [ -z "$body" ]; then
        log "drain complete — 0 polecats in pogod's registry"
        err "could not re-read /agents/drain to check for unreachable survivors"
        err "this is NOT a report that there are none — it is a report that we could not look"
        return 0
    fi

    # A witness we could not read means we do not know whether survivors exist.
    # That is NOT "none" and must not be printed as a clean drain (mg-76e5).
    errmsg="$(printf '%s' "$body" | json_str unreachable_err)"
    if [ -n "$errmsg" ]; then
        log "drain complete — 0 polecats in pogod's registry"
        err "cannot tell whether any polecat survived an earlier restart: $errmsg"
        err "proceeding, but this redeploy may bounce live work it cannot see"
        return 0
    fi

    leftovers="$(unreachable_list "$body")"
    if [ -z "$leftovers" ]; then
        log "drain complete — 0 polecats in the registry, none unreachable"
        return 0
    fi

    n="$(printf '%s\n' "$leftovers" | wc -l | tr -d ' ')"
    log "drain complete — 0 polecats in pogod's registry"
    err "$n polecat(s) are ALIVE but unreachable and were NOT drained:"
    printf '%s\n' "$leftovers" | while IFS= read -r line; do err "  $line"; done
    err "these survived an earlier pogod restart, so this registry cannot see them"
    err "and never will (no adopt path — absence never heals). They are still"
    err "holding a worktree and a claim. This redeploy does NOT touch them; they"
    err "need a human. pogod is also mailing the coordinator about each one."
    return 0
}

# On a forced hard bounce, clean up every polecat the bounce orphaned: unclaim
# its work item and gc its worktree. Input: the /agents/drain snapshot captured
# BEFORE the kickstart (after kickstart, pogod's registry is gone).
cleanup_orphans() {
    local snapshot="$1" line id wt repo
    # Extract "work_item_id":"..","worktree_dir":"..","source_repo":".." tuples.
    # One polecat object per line after we split on '},{'.
    #
    # `|| [ -n "$line" ]` is load-bearing — the third encounter with the trap
    # extract_mail_check_ids_for_agents and unreachable_list already document
    # above. The snapshot arrives from a `$(curl ...)`, and command substitution
    # strips trailing newlines, so the LAST object has none; a bare `read` sets
    # $line and then returns non-zero at EOF, and the loop body never runs for it.
    #
    # Here that is worse than a miss. This function only runs on a --force hard
    # bounce, over the population that bounce just killed — so the last polecat is
    # never unclaimed and its worktree is never removed, and nothing else will
    # ever come for it: the claim and the worktree leak permanently. With ONE
    # polecat it dropped all of them, logging nothing at all.
    #
    # The guard existed in this same file, with a comment explaining exactly this,
    # and it did not transfer. What made this copy live is not that the knowledge
    # was missing — it is that cleanup_orphans had no test, so getting it wrong
    # failed silently. The control below (mg-a558) is the part that can fail.
    printf '%s' "$snapshot" \
        | sed 's/},{/}\n{/g' \
        | while IFS= read -r line || [ -n "$line" ]; do
            id="$(printf '%s' "$line"  | json_str work_item_id)"
            wt="$(printf '%s' "$line"  | json_str worktree_dir)"
            repo="$(printf '%s' "$line" | json_str source_repo)"
            [ -z "$id" ] && [ -z "$wt" ] && continue
            if [ -n "$id" ]; then
                log "unclaiming orphaned work item $id"
                "$MG" unclaim "$id" 2>&1 | sed 's/^/  /' || err "mg unclaim $id failed"
            fi
            if [ -n "$wt" ] && [ -n "$repo" ] && git -C "$repo" rev-parse --git-dir >/dev/null 2>&1; then
                log "removing orphaned worktree $wt"
                git -C "$repo" worktree remove --force "$wt" 2>&1 | sed 's/^/  /' || true
            fi
        done
    # Reap any now-dangling worktree administrative entries.
    [ -n "$REPO" ] && git -C "$REPO" worktree prune 2>/dev/null || true
}

# Installs every binary in DEPLOYED_CMDS. The daemon and the CLI move together
# or not at all — that lockstep is the point, so the failure modes must not be
# able to move one without the other.
#
# COMPILE EVERYTHING BEFORE INSTALLING ANYTHING. `go install pkgA pkgB` is NOT
# all-or-nothing: it installs each package as that package finishes, so a
# compile error in the CLI still leaves a freshly-installed pogod on disk. That
# is measured, not assumed — a deliberately broken cmd/pogo installed pogod and
# nothing else. Building the whole set into a throwaway dir first turns a
# compile error into a refusal that has written nothing to GOBIN, and costs
# almost nothing: the install that follows is a build-cache hit, not a recompile.
#
# ITS HONEST LIMIT: this closes the compile-error window, not every window. A
# go install that dies for a non-compile reason (full disk, GOBIN perms) after
# writing pogod can still split the pair. The post-install check below is what
# catches that: it asks EVERY binary its revision and refuses unless they all
# report main, so a split pair fails the deploy loudly instead of shipping. A
# refusal here exits with the drain trap still armed, leaving the old pogod
# running and dispatching — the correct resting state for "we could not build".
do_build() {
    local name; local pkgs=()
    for name in "${DEPLOYED_CMDS[@]}"; do pkgs+=("./cmd/$name"); done
    log "building ${DEPLOYED_CMDS[*]} from $REPO ($DEPLOY_REF)"
    local head; head="$(git -C "$REPO" rev-parse HEAD 2>/dev/null)"
    if [ "$head" != "$MAIN" ]; then
        err "repo HEAD ($(short "$head")) != $DEPLOY_REF ($(short "$MAIN")); checkout $DEPLOY_REF first or pass --repo to a checkout on it"
        exit 4
    fi
    if [ -n "$(git -C "$REPO" status --porcelain 2>/dev/null)" ]; then
        err "repo $REPO has uncommitted changes; refusing to go install a dirty tree"
        exit 4
    fi
    # Stage: compile the whole set into a throwaway dir. A failure here has
    # written nothing to GOBIN.
    local stage; stage="$(mktemp -d)" || { err "cannot create a staging dir"; exit 4; }
    if ! ( cd "$REPO" && go build -o "$stage/" "${pkgs[@]}" ); then
        rm -rf "$stage"
        err "go build failed — refusing to install a partial set (nothing was written to GOBIN)"
        exit 4
    fi
    rm -rf "$stage"
    ( cd "$REPO" && go install "${pkgs[@]}" ) || { err "go install failed"; exit 4; }
    # Verify EVERY binary, not just the daemon: an install that silently skipped
    # one is exactly the failure this ticket exists to end, and it is only
    # detectable by asking each binary what revision it carries.
    for name in "${DEPLOYED_CMDS[@]}"; do
        local now; now="$(installed_rev "$name")"
        if [ "$now" != "$MAIN" ]; then
            err "post-install $name revision $(short "$now") != main $(short "$MAIN")"
            exit 4
        fi
        log "installed $name is now $(short "$now")"
    done
}

# ---------------------------------------------------------------------------
# do_prove — the deploy must not trust a detector it has not just proven can
# fail. Runs the live control against the BUILT ARTIFACT, both directions, and
# refuses to deploy unless it observes both (mg-bfe5).
#
# WHY THIS EXISTS: do_build runs `go install` and NO TESTS. The live control is
# wired into test.sh, so it runs at MERGE and never at DEPLOY — every redeploy
# before this shipped a pogod whose detector had never been exercised against it.
# The attended ones were not safe either; they were covered by a human standing
# there doing the detector's job by hand.
#
# AND MERGE-TIME PROOF DOES NOT SUBSTITUTE. It is tempting — the refinery really
# does re-gate on the exact tree that lands (mg-a9bb read it: attemptMerge orders
# fetch -> checkout -B -> rebase -> runQualityGates -> merge --ff-only, so the
# gate runs on the rebased worktree, there is no batch primitive, and --ff-only
# re-gates on a race). So "main is green" is NOT a decaying claim. It is still
# the wrong fact: a merge-time pass is a claim about a COMMIT, and what gets
# kickstarted is an ARTIFACT. `go install` reads a toolchain, a module cache and
# a build environment that the gate's machine did not necessarily share.
#
# WHY THIS SHAPE AND NOT A PATH LIST: "re-prove when the diff touches the reap"
# is a PROXY for "did this change break the detector?", and it inherits that
# proxy's decay — move the reap out of cmd/pogod/main.go and the list silently
# stops covering it. It fails OPEN: a check that can no longer fail, inside the
# mechanism protecting the thing we spent all night proving can fail. Tonight
# proved it twice (a `-eq 4` literal decayed on the next commit; mg-6b66's
# main.go:915 decayed on that same night's merges). Every decaying guard is a
# proxy for a question you could ask directly — and this question is directly
# observable, so it asks it: run the detector and see. This function names no
# path, judges no diff, and asserts nothing about the tree. It contains a
# measurement, not a claim, which is why it cannot rot.
#
# ITS HONEST LIMIT: per-run proof shows the detector WORKS; it cannot show its
# coverage is COMPLETE. Nothing self-proves coverage. That argues for expanding
# the control as new modes are learned — not for a human, who at 03:00 is asleep
# and awake would be reading these same signals by hand.
do_prove() {
    local ctl="$REPO/scripts/pogo-self-deploy_live_test.sh"
    # pogod specifically: the control proves the DAEMON's detector.
    local bin; bin="$(installed_bin pogod)"
    # ...and the CLI, because the drain gate now shells to `pogo agent witness`
    # to ask the on-disk witness whether the fleet is live (mg-65b2). That makes
    # the CLI part of the deploy's decision path, not just its payload, so the
    # control drives the artifact we are about to install rather than whatever
    # `pogo` the PATH happens to resolve. Same discipline as $bin above: prove
    # the thing being deployed, not a stand-in for it.
    local cli; cli="$(installed_bin pogo)"

    # The gate must fail CLOSED on its own absence. If the control is missing,
    # that is not "nothing to prove" — it is the detector's detector gone, which
    # is the exact fail-open this function exists to close.
    if [ ! -f "$ctl" ]; then
        err "live control $ctl not found — refusing to deploy a pogod whose detector cannot be proven"
        exit 9
    fi
    if [ ! -x "$bin" ]; then
        err "no installed pogod at $bin to prove — refusing to deploy"
        exit 9
    fi
    # Fail closed on the CLI's absence too, rather than letting the control
    # quietly source-build one: do_build installs pogo in lockstep with pogod
    # (mg-ddf1), so a missing artifact here means the build did not do what it
    # said, and proving a binary we then do not deploy proves nothing.
    if [ ! -x "$cli" ]; then
        err "no installed pogo CLI at $cli to prove — refusing to deploy"
        err "the drain gate shells to 'pogo agent witness' when pogod stops answering (mg-65b2),"
        err "so an unproven CLI is an unproven gate."
        exit 9
    fi

    # Re-entrancy: fail LOUD, never skip. The live control drives real
    # cmd_redeploy runs, and today every one of them dies in do_build (exit 4)
    # and so never reaches here — but that is a CLAIM about the control, and
    # claims rot. If one ever gets past the build, this turns an infinite
    # recursion of 2-minute daemon-spawning runs into one legible error. Skipping
    # instead would mean a stray env var silently downgrades a deploy to the
    # unproven behaviour this ticket removes, which is the wrong direction to
    # fail in.
    if [ -n "${POGO_DEPLOY_PROVING:-}" ]; then
        err "do_prove re-entered from inside the live control (POGO_DEPLOY_PROVING is set) — refusing to recurse"
        exit 9
    fi

    log "proving the detector against the built artifact $(short "$(installed_rev pogod)") ($bin)"
    log "  running $ctl — both directions, ~2min; a deploy does not trust an unproven detector"

    # Capture rather than stream: the verdict is drawn from the tokens, so the
    # output has to be readable afterwards. It is echoed on failure only — on
    # success the two PROVED lines below are the whole story.
    local out rc=0
    out="$(POGO_DEPLOY_PROVING=1 POGO_LIVE_CONTROL_POGOD="$bin" POGO_LIVE_CONTROL_POGO="$cli" bash "$ctl" 2>&1)" || rc=$?

    if [ "$rc" -ne 0 ]; then
        err "the live control FAILED against the built artifact (exit $rc) — refusing to deploy a pogod whose detector does not work on it"
        printf '%s\n' "$out" | sed 's/^/  control: /'
        exit 9
    fi

    # BOTH DIRECTIONS OR NOTHING. Not the exit code: exit 0 only means nothing
    # that ran failed, and cannot tell a run that demonstrated both directions
    # from one where the RED control was deleted, skipped, or never reached. A
    # control that only demonstrates RED can be hard-wired to RED; one that only
    # demonstrates GREEN is decoration. So assert on what was OBSERVED.
    local saw_red=false saw_green=false
    printf '%s\n' "$out" | grep -q '^PROVED: RED$'   && saw_red=true
    printf '%s\n' "$out" | grep -q '^PROVED: GREEN$' && saw_green=true

    if ! $saw_red || ! $saw_green; then
        err "the live control exited 0 but did not demonstrate both directions against the artifact (RED=$saw_red GREEN=$saw_green) — refusing to deploy on a detector that was not shown able to fail AND able to pass"
        printf '%s\n' "$out" | sed 's/^/  control: /'
        exit 9
    fi

    log "proven on this artifact: detector goes RED on a broken fleet and GREEN on an intact one"
}

do_restart() {
    local target="gui/$(id -u)/$DAEMON_LABEL"
    log "restarting pogod: launchctl kickstart -k $target"
    # ALWAYS kickstart — never rely on KeepAlive to pick up a stopped job
    # (mg-6afa mechanism 2 / mg-50e0). -k kills the running instance first.
    $LAUNCHCTL kickstart -k "$target" || { err "launchctl kickstart failed"; exit 5; }
}

verify_running() {
    local deadline=$(( $(date +%s) + 60 )) rev
    while :; do
        rev="$(running_rev)"
        if [ "$rev" = "$MAIN" ]; then
            log "verified: new pogod running at $(short "$rev")"
            return 0
        fi
        if [ "$(date +%s)" -ge "$deadline" ]; then
            err "new pogod did not report main revision within 60s (got '${rev:-unreachable}')"
            return 1
        fi
        sleep 3
    done
}

cmd_redeploy() {
    # FIRST, ahead of every other precondition (mg-1bbf). Not because it is the
    # most likely refusal but because it is the only one whose failure mode is
    # the fleet: everything below this line assumes the caller is allowed to
    # kill pogod's process tree, and that assumption is checked here or nowhere.
    assert_out_of_band

    # Resolve the macguffin `mg` to an absolute path up front. The redeploy's
    # entire alert path (mail_alert) and its orphan cleanup call `mg`; a redeploy
    # whose alerter cannot be resolved is a redeploy that cannot report its own
    # stalls — refuse it loudly rather than ship a silent one (mg-015f).
    resolve_mg || { err "cannot resolve the macguffin 'mg' — refusing to redeploy with an unusable alert path"; exit 1; }
    resolve_repo
    compute_drift
    print_drift
    if ! classify_drift; then err "$ACTION"; exit 1; fi
    echo "action    : $ACTION"
    if ! $NEEDS_BUILD && ! $NEEDS_RESTART; then
        log "nothing owed — pogod is already at main. Done."
        exit 0
    fi

    confirm

    # 1. Signal drain (stop dispatching new polecats) and let the fleet quiesce.
    #    Disambiguate three POST /agents/drain outcomes (mg-065e): endpoint
    #    present (drain), endpoint absent but server up (bootstrap — a pogod
    #    predating mg-cae1), and pogod genuinely down. Each has a DIFFERENT
    #    remedy, so they must not collapse into one "is pogod up?" message.
    local snapshot leftover=0
    if $SKIP_DRAIN; then
        # Operator-directed skip (or the bootstrap remedy). No drain, no fleet
        # quiesce, no snapshot — the kickstart -k below will bounce whatever is
        # running. Explicit acknowledgement of the un-drained bounce.
        log "--skip-drain: skipping drain phase (no fleet quiesce, no orphan cleanup)"
    else
        log "enabling drain mode"
        # Read dispatch as it stands BEFORE we touch it, then arm the restore.
        # Armed BEFORE the POST, not after, on purpose: a POST that times out
        # AFTER pogod set the flag comes back "000" and classifies as `down`,
        # so the one path where we cannot tell whether we mutated anything is a
        # path that must still restore. A restore POST on a genuinely-down or
        # bootstrap daemon fails harmlessly and says so; the reverse mistake is
        # a silent fleet-wide outage.
        DRAIN_PRIOR="$(drain_state)"
        DRAIN_ARMED=true
        # ONLY the EXIT trap restores. INT/TERM merely convert the signal into an
        # exit, because a bash signal handler that RETURNS resumes the script
        # where it was interrupted: `trap restore_drain EXIT INT TERM` would
        # restore dispatch on Ctrl-C and then carry on building and kickstarting
        # with the fleet live — a cleanup that fires and then un-fires itself.
        # Routing both through exit gives one restore, on one path, with the
        # signal's status preserved.
        trap restore_drain EXIT
        trap 'err "interrupted (SIGINT) during the drain window"; exit 130' INT
        trap 'err "terminated (SIGTERM) during the drain window"; exit 143' TERM
        local disp; disp="$(classify_drain_precondition "$(drain_post true)")"
        case "$disp" in
            drain)
                # Take drain_wait's OWN verdict and its OWN number, rather than
                # re-reading the endpoint for a third opinion (mg-65b2). The old
                # re-fetch was redundant on the timeout path and actively wrong
                # on the new one: when drain_wait refuses because pogod went
                # silent, that curl fails too, `${leftover:-?}` renders "?", and
                # the script announced "? polecat(s) still active after 1800s
                # drain timeout" — a confident story about a deadline that never
                # passed, over a state we had just admitted we could not read.
                # Telling a timeout's story about an unknown is this ticket's own
                # defect rebuilt inside its fix.
                local drain_rc=0 leftover
                leftover="$(drain_wait)" || drain_rc=$?
                if [ "$drain_rc" -eq 0 ]; then
                    report_drain_complete
                else
                    leftover="${leftover:-?}"
                    if ! $FORCE; then
                        if [ "$drain_rc" -eq 2 ]; then
                            # The drain could not establish the fleet's state and
                            # has already said why, in detail, above.
                            err "the drain could not establish whether the fleet is idle (see above)"
                            err "refusing to bounce a fleet whose state is unknown; restoring dispatch"
                        else
                            err "$leftover polecat(s) still active after ${DRAIN_TIMEOUT}s drain timeout"
                            err "refusing to hard-bounce the fleet without --force; restoring dispatch"
                        fi
                        # The two err lines above are the ATTENDED report: they
                        # work because a human ran this and is reading them. The
                        # sink below is the UNATTENDED one, and it is not a
                        # louder version of them — it leaves the script (mg-f206).
                        # Fired BEFORE the exit, not from the trap: the trap runs
                        # on every armed exit path, and a sink that fires on all
                        # of them announces failures that are already reported by
                        # something else. This one is scoped to the single outcome
                        # nothing else can see — the run that changed NOTHING.
                        # The sink is told WHICH refusal this is: a busy fleet
                        # and an unreadable one need opposite reactions from the
                        # operator, and one story for both would mis-advise half
                        # the pages it sends (mg-65b2).
                        if [ "$drain_rc" -eq 2 ]; then
                            alert_drain_stalled unknown "$leftover"
                        else
                            alert_drain_stalled timeout "$leftover"
                        fi
                        # The restore is the trap's job now — and the trap puts
                        # back the PRIOR value, where the bare `drain_post false`
                        # that used to live here asserted `false` unconditionally.
                        # This path was the ONLY one that restored anything; every
                        # other exit between here and the kickstart leaked drain.
                        exit 7
                    fi
                    if [ "$drain_rc" -eq 2 ]; then
                        # Do not promise the cleanup here. The snapshot below is
                        # fetched from the daemon we just failed to read, so on
                        # this path it comes back EMPTY and cleanup_orphans has
                        # nothing to work from — no unclaim, no worktree removal.
                        # The timeout path's message can promise cleanup because
                        # pogod is answering there; saying it here would be one
                        # more confident claim about a state we cannot see, which
                        # is the whole thing this ticket removes.
                        log "--force: bouncing WITHOUT knowing whether polecats are live (the drain could not tell)"
                        log "--force: if any are, they will survive the bounce and keep their claims + worktrees;"
                        log "--force: no snapshot is readable from a silent pogod, so nothing will be cleaned up"
                    else
                        log "--force: hard-bouncing with $leftover polecat(s) active; will clean up after"
                    fi
                fi
                # Capture the pre-kickstart polecat snapshot for post-bounce cleanup.
                snapshot="$(curl -sf --max-time 5 "$(base_url)/agents/drain" 2>/dev/null)"
                ;;
            bootstrap)
                err "bootstrap: this pogod predates the /agents/drain endpoint (HTTP 404 from mg-cae1's feature)"
                err "the pogod you are replacing does not yet have the drain feature you are deploying —"
                err "the one-time self-deploy chicken-and-egg. Nothing to drain via the API."
                err "re-run with --skip-drain to rebuild+restart without draining (safe when the fleet is idle)."
                exit 6
                ;;
            down)
                err "pogod is not answering POST $(base_url)/agents/drain (connection refused / timeout)"
                err "this is NOT the bootstrap case — the server did not respond at all. Start pogod, then retry."
                exit 6
                ;;
            error:*)
                err "unexpected HTTP ${disp#error:} from POST /agents/drain; refusing to proceed"
                exit 6
                ;;
        esac
    fi

    # 2. Build (only if a build is owed — a restart-only drift skips go install
    #    so we do not pay a rebuild we do not need).
    if $NEEDS_BUILD; then
        do_build
    else
        log "installed already matches main — skipping go install (restart-only)"
    fi

    # 2a. Prove the detector against the artifact we are about to kickstart into
    #     — RED on a broken fleet, GREEN on an intact one — or refuse to deploy.
    #
    #     EVERY run, not just $NEEDS_BUILD runs. A restart-only deploy installs
    #     nothing, but it still kickstarts the fleet onto that binary and still
    #     leans on the post-check at step 5 to tell it whether the mail loop
    #     survived; the artifact being older than this run does not make its
    #     detector proven. Gating this on NEEDS_BUILD would also make the
    #     guarantee conditional on a drift classification — i.e. back to a claim
    #     about when proof is needed, which is the shape that rots.
    #
    #     Deliberately INSIDE the drain window, per the ticket: after go install,
    #     before do_restart. It costs ~2min of drain, and a refusal here exits
    #     while the trap is still armed — so the restore puts dispatch back
    #     exactly as it does for a failed build (mg-8b48). A refusal to deploy
    #     therefore leaves the OLD pogod running and the fleet dispatching, which
    #     is the correct resting state for "we could not prove the new one".
    do_prove

    # 3. Restart (always kickstart) and verify the new process is main.
    #    Read the fleet's mail-checks FIRST — the old pogod is the only thing
    #    that can tell us what there was to preserve (mg-de08). Keep the whole
    #    body, not just the ids: step 5 needs the agent each schedule is
    #    addressed to in order to name the losses a forced bounce explains, and
    #    after the kickstart there is nothing left to ask (mg-ea3e).
    local mail_pre_body="" mail_pre
    if mail_pre_body="$(schedules_body)"; then
        mail_pre="$(printf '%s' "$mail_pre_body" | extract_mail_check_ids)"
    else
        mail_pre="?"
    fi
    # Disarm BEFORE the kickstart: it kills the pogod whose dispatch flag we
    # mutated, so from here there is no state left to restore and no process to
    # restore it on. The replacement starts with draining at its zero value.
    # This is the far edge of the window mg-46a4 identified; past it, a restore
    # POST would be aimed at a DIFFERENT daemon than the one we changed — and if
    # drain had been on before, it would re-drain the fresh fleet.
    DRAIN_ARMED=false
    trap - EXIT INT TERM
    do_restart
    verify_running || exit 8

    # 4. If a forced bounce killed active polecats, clean up the wreckage.
    if [ "$leftover" != "0" ] && [ "$leftover" != "?" ]; then
        log "cleaning up $leftover polecat(s) orphaned by the forced bounce"
        cleanup_orphans "$snapshot"
    fi

    # 5. Assert the fleet's mail loop survived the bounce. Reports only — the
    #    daemon is already up; a mail-check gap is an alarm to act on, not a
    #    reason to call a completed deploy failed (mg-de08).
    #
    #    Slack is the SET of schedules the force-killed polecats took with them,
    #    looked up BY NAME out of the pre-bounce body — never the NUMBER of dead
    #    polecats (mg-ea3e). The two differ exactly when a dead polecat had no
    #    mail-check to lose: the count hands out an allowance nothing earned,
    #    and a real crew loss disappears under it without a word.
    local mail_slack=""
    if [ -n "$mail_pre_body" ] && [ "$leftover" != "0" ] && [ "$leftover" != "?" ]; then
        mail_slack="$(expected_lost_mail_checks "$mail_pre_body" "$snapshot")"
    fi
    verify_mail_checks_restored "$mail_pre" "$mail_slack"

    log "redeploy complete."
}

# ---------------------------------------------------------------------------
# Arg parsing
# ---------------------------------------------------------------------------
usage() {
    sed -n '2,40p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
}

main() {
    [ $# -ge 1 ] || { usage; exit 2; }
    local subcmd="$1"; shift
    while [ $# -gt 0 ]; do
        case "$1" in
            --yes)            ASSUME_YES=true ;;
            --force)          FORCE=true ;;
            --skip-drain)     SKIP_DRAIN=true ;;
            --drain-timeout)  DRAIN_TIMEOUT="$2"; shift ;;
            --repo)           REPO="$2"; shift ;;
            --port)           PORT="$2"; shift ;;
            -h|--help)        usage; exit 0 ;;
            *)                err "unknown flag: $1"; usage; exit 2 ;;
        esac
        shift
    done

    case "$subcmd" in
        check)     cmd_check ;;
        redeploy)  cmd_redeploy ;;
        -h|--help) usage; exit 0 ;;
        *)         err "unknown subcommand: $subcmd"; usage; exit 2 ;;
    esac
}

# Run main only when executed directly, so a test harness can source this file
# to exercise the pure helpers (classify_drift, json_str) without dispatching.
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
